# Catmoji local environment template
#
# 1. Copy this file to .env for local development.
# 2. Add the real values only to .env and Vercel Environment Variables.
# 3. Never commit real API keys, even in this example file.

# Comma-separated Gemini API keys used by api/tts.js.
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2

# Optional default voice. The app can still choose a voice per request.
GEMINI_TTS_VOICE=Sulafat

# Optional model override. Omit this line to use the proxy default.
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
