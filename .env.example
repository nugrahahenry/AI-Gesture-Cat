# ─── Gesture TTS — Environment Variables ───────────────────────────────────
# Cara pakai:
#   • Lokal (vercel dev): copy file ini jadi `.env`, isi key ASLI di sana.
#   • Production: set var ini di Vercel → Project → Settings → Environment Variables.
#
# ⚠️ JANGAN tulis key asli di file ini — ini ke-commit ke GitHub publik.
#    Key asli HANYA di `.env` (gitignored) & di Vercel env vars.
#
# Key Gemini dialokasikan KHUSUS Gesture (4 key standar). Sisanya DICADANGKAN
# untuk Canox. Lihat API_KEY_ALLOCATION.md di root project.

# Daftar API key Gemini, dipisah KOMA (rotasi otomatis anti rate-limit).
GEMINI_API_KEYS=AIza_KEY_1_DISINI,AIza_KEY_2_DISINI,AIza_KEY_3_DISINI,AIza_KEY_4_DISINI

# (opsional) Voice default. Pilihan natural buat intro ramah:
#   Sulafat (warm) · Achird (friendly) · Aoede (breezy) · Leda (youthful) · Kore (firm)
GEMINI_TTS_VOICE=Sulafat

# (opsional) Override model. Default sudah stabil; kosongkan kalau ragu.
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
